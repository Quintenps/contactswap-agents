{
  "name": "@contactswap/api",
  "version": "0.0.1",
  "private": true,
  "description": "ContactSwap API - Cloudflare Worker",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply contactswap-db",
    "db:migrate:local": "wrangler d1 migrations apply contactswap-db --local"
  },
  "dependencies": {
    "@contactswap/shared": "*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.95.0"
  }
}

