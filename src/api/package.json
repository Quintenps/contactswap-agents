{
  "name": "@contactswap/api",
  "version": "0.0.1",
  "private": true,
  "description": "ContactSwap API - Cloudflare Worker",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply contactswap-db",
    "db:migrate:local": "wrangler d1 migrations apply contactswap-db --local"
  },
  "dependencies": {
    "@contactswap/shared": "*",
    "hono": "^4.12.14",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260421.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.84.1"
  }
}

